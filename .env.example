# sport_enginuity — Environment Variables
# Copy this file to .env and fill in your API keys.

# ── Provider API Keys ───────────────────────────────────────
# Phase 1 providers (NFL, NBA, MLB)
BALLDONTLIE_API_KEY=           # https://www.balldontlie.io/ (NBA)
SPORTSDATA_API_KEY=            # https://sportsdata.io/ (NFL, NBA, MLB)
THE_ODDS_API_KEY=              # https://the-odds-api.com/ (betting odds)

# Phase 2+ providers
ESPN_API_KEY=                  # ESPN public API (no key required for some endpoints)
API_SPORTS_KEY=                # https://www.api-football.com/
SPORTMONKS_API_TOKEN=          # https://www.sportmonks.com/

# ── API Server ──────────────────────────────────────────────
PORT=3000                      # REST API server port
API_RATE_LIMIT=100             # Requests per minute per client

# ── Database (future) ──────────────────────────────────────
# DATABASE_URL=                # PostgreSQL connection string

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info                 # debug | info | warn | error
