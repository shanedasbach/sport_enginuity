{
  "name": "sport-enginuity",
  "version": "0.1.0",
  "description": "Unified sports data platform — ingest, normalize, and serve multi-sport stats, fantasy, and betting data via API, CLI, and AI chatbot.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "se": "tsx src/index.ts"
  },
  "bin": {
    "se": "./dist/index.js"
  },
  "keywords": [
    "sports",
    "data",
    "api",
    "normalization",
    "fantasy",
    "betting",
    "nfl",
    "nba",
    "mlb",
    "cli"
  ],
  "author": "Shane Dasbach",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
